PORT=4000
DATABASE_URL="file:./dev.db"
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_secret
STRAVA_REDIRECT_URI=http://localhost:4000/auth/strava/callback
STRAVA_WEBHOOK_VERIFY_TOKEN=change_me
STRAVA_WEBHOOK_CALLBACK_URL=http://localhost:4000/webhook/strava
# Wikipedia Action API (geosearch) — no API key required for read-only use
WIKIPEDIA_ORIGIN=https://en.wikipedia.org
WIKIPEDIA_SEARCH_RADIUS=1500
# Optional: identify your app per https://www.mediawiki.org/wiki/API:Etiquette
# WIKIPEDIA_USER_AGENT=MyApp/1.0 (https://example.com; contact@example.com)
BASE_APP_URL=http://localhost:5173
